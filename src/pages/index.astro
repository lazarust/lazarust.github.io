---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="~/">
  <div class="prompt-line">
    <span class="prompt-user">~</span>
    <span class="prompt-sep">$</span>
    <span class="prompt-cmd">whoami</span>
  </div>
  <p class="intro">
    Thomas — data practitioner with 6+ years building production-grade data systems and ML-powered tooling.
    I write about data engineering, ML, and the tools I use along the way.
  </p>

  <div class="prompt-line">
    <span class="prompt-user">~</span>
    <span class="prompt-sep">$</span>
    <span class="prompt-cmd">ls</span>
  </div>

  <div class="ls-listing">
    <div class="ls-row">
      <span class="ls-date"></span>
      <span class="ls-size">-</span>
      <a href="/about/" data-nav-item>about.md</a>
    </div>
    <div class="ls-row">
      <span class="ls-date"></span>
      <span class="ls-size">-</span>
      <a href="/blog/" data-nav-item>blog</a>
    </div>
  </div>
</BaseLayout>
