---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { type CollectionEntry } from 'astro:content';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const published = await getPublishedPosts();
  const categories = [...new Set(published.flatMap((p: CollectionEntry<'posts'>) => p.data.categories ?? []))];
  return categories.map(cat => ({
    params: { category: cat },
    props: { category: cat, posts: published.filter((p: CollectionEntry<'posts'>) => p.data.categories?.includes(cat)) },
  }));
}

const { category, posts } = Astro.props;
const sorted = posts.sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`Category: ${category}`}>
  <nav class="nav-links"><a href="/" data-nav-item>&larr; home</a></nav>
  <div class="prompt-line">
    <span class="prompt-user">~/blog</span>
    <span class="prompt-sep">$</span>
    <span class="prompt-cmd">ls {category}/</span>
  </div>
  <div class="ls-listing">
    {sorted.map((post: CollectionEntry<'posts'>) => (
      <div class="ls-row">
        <span class="ls-date">{post.data.date.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' })}</span>
        <a href={`/posts/${post.id}/`} data-nav-item data-list-item>{post.data.title}</a>
      </div>
    ))}
  </div>
</BaseLayout>
