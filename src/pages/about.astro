---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

const pages = await getCollection('pages');
const about = pages.find((p: CollectionEntry<'pages'>) => p.id === 'about');
if (!about) {
  throw new Error('about.md not found in src/content/pages/');
}
const { Content } = await render(about);
---

<BaseLayout title="About">
  <nav class="nav-links"><a href="/" data-nav-item>&larr; home</a></nav>
  <div class="prompt-line">
    <span class="prompt-user">~</span>
    <span class="prompt-sep">$</span>
    <span class="prompt-cmd">cat about.md</span>
  </div>
  <article class="post-content">
    <Content />
  </article>
</BaseLayout>
